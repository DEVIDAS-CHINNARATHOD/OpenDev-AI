# ── GitHub ─────────────────────────────────────────────────────────────────────
# Personal Access Token with "repo" scope
GITHUB_TOKEN=

# ── Git commit identity ─────────────────────────────────────────────────────────
GIT_AUTHOR_NAME=OpenDev AI Bot
GIT_AUTHOR_EMAIL=opendev-ai@users.noreply.github.com

# ── LLM Providers (priority: Claude > Gemini > Groq) ────────────────────────────
# At least ONE provider is required

# Anthropic Claude — highest priority
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# Google Gemini — second priority
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Groq (Meta Llama) — fallback
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ── CORS (required for production) ──────────────────────────────────────────────
# Comma-separated list of exact allowed origins
# Example: FRONTEND_ORIGIN=https://opendev.example.com,https://www.opendev.example.com
FRONTEND_ORIGIN=

# Regex pattern for dynamic origins (e.g. Vercel preview deployments)
# Example: FRONTEND_ORIGIN_REGEX=https://.*\.vercel\.app
FRONTEND_ORIGIN_REGEX=

# ── Optional tuning ─────────────────────────────────────────────────────────────
# Timeout in seconds for shell commands (git clone, npm test, pytest, etc.)
COMMAND_TIMEOUT_SECONDS=300
